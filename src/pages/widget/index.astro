---
import Layout from '../../layouts/Layout.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://salairenet.lu/" },
    { "@type": "ListItem", "position": 2, "name": "Widget", "item": "https://salairenet.lu/widget/" }
  ]
};

const embedCode = `<iframe src="https://salairenet.lu/" width="100%" height="700" frameborder="0" style="border:none;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1);" title="Calculateur salaire net Luxembourg"></iframe>`;
---
<Layout title="Integrer le calculateur de salaire net Luxembourg - Widget" description="Integrez notre calculateur de salaire brut-net Luxembourg sur votre site web gratuitement avec un simple code iframe.">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <nav class="text-sm text-gray-500 mb-8">
    <ol class="flex items-center gap-2">
      <li><a href="/" class="hover:text-gray-700">Accueil</a></li>
      <li>/</li>
      <li class="text-gray-800 font-medium">Widget</li>
    </ol>
  </nav>

  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-900 mb-4">Integrer notre calculateur sur votre site</h1>
    <p class="text-gray-600 mb-8">Vous etes un cabinet RH, une fiduciaire ou un portail d'emploi au Luxembourg ? Integrez gratuitement notre calculateur de salaire brut-net sur votre site en copiant le code ci-dessous.</p>

    <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">Code d'integration</h2>
      <p class="text-gray-600 mb-4">Copiez le code HTML suivant et collez-le dans votre page web a l'endroit ou vous souhaitez afficher le calculateur :</p>
      <div class="relative">
        <pre class="bg-gray-900 text-green-400 rounded-lg p-4 text-sm overflow-x-auto"><code>{embedCode}</code></pre>
        <button
          onclick="navigator.clipboard.writeText(this.closest('.relative').querySelector('code').textContent);this.textContent='Copie !';setTimeout(()=>this.textContent='Copier',2000)"
          class="absolute top-3 right-3 px-3 py-1 bg-gray-700 text-white text-xs rounded hover:bg-gray-600 transition-colors"
        >Copier</button>
      </div>
    </section>

    <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">Comment l'integrer</h2>
      <ol class="space-y-4 text-gray-600">
        <li class="flex items-start gap-3">
          <span class="flex-shrink-0 w-8 h-8 bg-teal-100 text-teal-700 rounded-full flex items-center justify-center font-bold text-sm">1</span>
          <span><strong>Copiez le code</strong> : cliquez sur le bouton "Copier" ci-dessus pour copier le code iframe dans votre presse-papier.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex-shrink-0 w-8 h-8 bg-teal-100 text-teal-700 rounded-full flex items-center justify-center font-bold text-sm">2</span>
          <span><strong>Ouvrez votre editeur</strong> : accedez a l'editeur HTML de votre site, blog ou CMS (WordPress, Wix, Squarespace, etc.).</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex-shrink-0 w-8 h-8 bg-teal-100 text-teal-700 rounded-full flex items-center justify-center font-bold text-sm">3</span>
          <span><strong>Collez le code</strong> : inserez le code HTML a l'emplacement souhaite dans votre page, par exemple dans un article sur les salaires au Luxembourg.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="flex-shrink-0 w-8 h-8 bg-teal-100 text-teal-700 rounded-full flex items-center justify-center font-bold text-sm">4</span>
          <span><strong>Publiez</strong> : enregistrez et publiez votre page. Le calculateur s'affichera automatiquement et sera utilisable par vos visiteurs.</span>
        </li>
      </ol>
    </section>

    <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">Options de personnalisation</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 font-semibold text-gray-700">Attribut</th>
              <th class="px-4 py-3 font-semibold text-gray-700">Valeur par defaut</th>
              <th class="px-4 py-3 font-semibold text-gray-700">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="px-4 py-3 font-mono text-teal-700">width</td>
              <td class="px-4 py-3">100%</td>
              <td class="px-4 py-3 text-gray-600">Largeur du widget. Accepte les pourcentages ou les pixels (ex: "800px").</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-mono text-teal-700">height</td>
              <td class="px-4 py-3">700</td>
              <td class="px-4 py-3 text-gray-600">Hauteur du widget en pixels. Augmentez cette valeur si le contenu est tronque.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-mono text-teal-700">style</td>
              <td class="px-4 py-3">border-radius, box-shadow</td>
              <td class="px-4 py-3 text-gray-600">Styles CSS personnalisables. Modifiez les coins arrondis ou l'ombre selon votre charte graphique.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">Apercu du widget</h2>
      <p class="text-gray-600 mb-4">Voici un apercu du calculateur tel qu'il apparaitra sur votre site :</p>
      <div class="border border-gray-200 rounded-lg overflow-hidden">
        <iframe src="/" width="100%" height="700" frameborder="0" style="border:none;border-radius:8px;" title="Apercu du calculateur salaire net Luxembourg"></iframe>
      </div>
    </section>
  </div>
</Layout>

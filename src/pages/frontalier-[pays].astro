---
import Layout from '../layouts/Layout.astro';
import SalaryCalculator from '../components/SalaryCalculator';
import { frontalierData, type FrontalierEntry } from '../lib/frontalier-data';
import { salairesData } from '../lib/salaires-data';

export function getStaticPaths() {
  return frontalierData.map((entry) => ({
    params: { pays: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: FrontalierEntry;
}

const { entry } = Astro.props;

const title = `Frontalier ${entry.country}-Luxembourg - Calcul salaire net 2026`;
const description = `Guide complet pour les frontaliers ${entry.country.toLowerCase()}-Luxembourg : fiscalité, télétravail (${entry.teleworkThreshold} jours), sécurité sociale, classe d'impôt. Simulateur salaire net 2026.`;

// Other frontalier pages for cross-links
const otherFrontaliers = frontalierData.filter((f) => f.slug !== entry.slug);

// Breadcrumb JSON-LD
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Accueil",
      "item": "https://salairenet.lu/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": `Frontalier ${entry.country}`,
      "item": `https://salairenet.lu/frontalier-${entry.slug}/`
    }
  ]
};

// FAQPage JSON-LD
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": entry.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout title={title} description={description} canonical={`https://salairenet.lu/frontalier-${entry.slug}/`}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div class="space-y-10">
    <!-- Breadcrumb -->
    <nav aria-label="Fil d'Ariane" class="text-sm text-gray-500">
      <ol class="flex items-center gap-2">
        <li>
          <a href="/" class="hover:text-primary transition-colors">Accueil</a>
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <span class="text-gray-900 font-medium">Frontalier {entry.country}</span>
        </li>
      </ol>
    </nav>

    <!-- Trust badge -->
    <div class="flex flex-wrap items-center gap-3 mb-6 text-xs text-gray-500">
      <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 px-2.5 py-1 font-medium text-gray-900">
        <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
        </svg>
        Mis à jour pour 2026
      </span>
      <span>
        Par <a href="/a-propos/" class="font-medium text-gray-700 hover:text-primary">Mottalib Radif, MBA INSEAD</a>
      </span>
    </div>

    <!-- Title -->
    <div class="text-center max-w-3xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Frontalier {entry.country}-Luxembourg : calcul du salaire net
      </h1>
      <p class="text-lg text-gray-600 leading-relaxed">
        Guide complet 2026 pour les travailleurs frontaliers résidant en {entry.country} et travaillant au Luxembourg.
        Fiscalité, cotisations sociales, télétravail et simulateur de salaire net.
      </p>
    </div>

    <!-- Key stats cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="bg-blue-50 rounded-xl border border-blue-100 p-6 text-center">
        <p class="text-sm text-gray-500 mb-2">Seuil télétravail fiscal</p>
        <p class="text-3xl font-bold text-primary">{entry.teleworkThreshold} jours</p>
        <p class="text-xs text-gray-400 mt-1">par an sans impact fiscal</p>
      </div>
      <div class="bg-green-50 rounded-xl border border-green-100 p-6 text-center">
        <p class="text-sm text-gray-500 mb-2">Cotisations sociales</p>
        <p class="text-3xl font-bold text-green-600">12,2 %</p>
        <p class="text-xs text-gray-400 mt-1">prélevées au Luxembourg</p>
      </div>
      <div class="bg-purple-50 rounded-xl border border-purple-100 p-6 text-center">
        <p class="text-sm text-gray-500 mb-2">Sécurité sociale</p>
        <p class="text-3xl font-bold text-purple-600">49 %</p>
        <p class="text-xs text-gray-400 mt-1">seuil télétravail sécurité sociale</p>
      </div>
    </div>

    <!-- Description / SEO content -->
    <div class="prose prose-slate max-w-none">
      <h2>Travailler au Luxembourg en résidant en {entry.country}</h2>
      {entry.description.split('\n\n').map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>

    <!-- Tax rules -->
    <div class="bg-white rounded-xl shadow-sm border border-border p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Règles fiscales clés - Frontalier {entry.country}-Luxembourg</h2>
      <ul class="space-y-3">
        {entry.taxRules.map((rule) => (
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-gray-700">{rule}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Telework section -->
    <div class="prose prose-slate max-w-none">
      <h2>Télétravail pour les frontaliers {entry.country.toLowerCase()}-Luxembourg</h2>
      <p>
        Les frontaliers résidant en {entry.country} et travaillant au Luxembourg bénéficient d'un seuil de tolérance
        de <strong>{entry.teleworkThreshold} jours</strong> de télétravail par an sans impact sur leur imposition au Luxembourg.
        Ce seuil, négocié dans le cadre d'un accord bilatéral entre le Luxembourg et la {entry.country}, permet aux
        frontaliers de télétravailler ponctuellement depuis leur domicile sans déclencher une obligation fiscale
        dans leur pays de résidence.
      </p>
      <p>
        Au-delà de {entry.teleworkThreshold} jours de télétravail depuis la {entry.country}, les revenus correspondant
        aux jours de télétravail deviennent imposables en {entry.country} selon le barème fiscal {entry.slug === 'france' ? 'français' : entry.slug === 'belgique' ? 'belge' : 'allemand'}.
        Il est donc essentiel de comptabiliser précisément les jours de télétravail et de conserver des justificatifs
        (attestation de l'employeur, relevés de badgeuse, etc.).
      </p>
      <p>
        En matière de sécurité sociale, le cadre est différent et plus favorable : l'accord-cadre européen
        sur le télétravail transfrontalier, applicable depuis le 1er juillet 2023, permet aux frontaliers de
        télétravailler jusqu'à 49 % de leur temps de travail total sans changement d'affiliation à la sécurité
        sociale. Cela signifie qu'un frontalier peut télétravailler près de 2,5 jours par semaine tout en
        restant affilié à la CNS luxembourgeoise, à condition que le télétravail soit effectué depuis son
        pays de résidence.
      </p>

      <h2>Sécurité sociale des frontaliers {entry.slug === 'france' ? 'français' : entry.slug === 'belgique' ? 'belges' : 'allemands'}</h2>
      <p>
        Les frontaliers travaillant au Luxembourg sont affiliés au régime de sécurité sociale luxembourgeois,
        quel que soit leur pays de résidence. Ils cotisent à la CNS (assurance maladie), à l'assurance pension
        et à l'assurance dépendance, aux mêmes taux que les résidents : 2,8 % + 8 % + 1,4 % = 12,2 % du
        salaire brut. L'employeur verse des cotisations patronales équivalentes.
      </p>
      <p>
        La couverture maladie de la CNS est valable au Luxembourg et dans le pays de résidence du frontalier.
        Grâce à la carte européenne d'assurance maladie (CEAM), le frontalier et ses ayants droit peuvent
        se faire soigner en {entry.country} aux conditions du système de soins {entry.slug === 'france' ? 'français' : entry.slug === 'belgique' ? 'belge' : 'allemand'}. Le remboursement est effectué
        par la CNS luxembourgeoise selon ses propres barèmes, qui sont généralement avantageux.
      </p>
      <p>
        Pour la pension de retraite, le frontalier accumule des droits dans le régime luxembourgeois pendant
        toute la durée de son emploi au Grand-Duché. À la retraite, il percevra une pension luxembourgeoise
        proportionnelle à ses années de cotisation, en complément de toute pension acquise dans son pays de
        résidence. Les périodes d'assurance sont coordonnées au niveau européen pour garantir la totalisation
        des droits.
      </p>
    </div>

    <!-- Embedded Calculator -->
    <div>
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Calculez votre salaire net de frontalier</h2>
      <p class="text-gray-600 mb-4">
        Utilisez notre simulateur ci-dessous pour calculer votre salaire net. Activez l'option
        « Frontalier » pour adapter le calcul à votre situation de travailleur transfrontalier
        résidant en {entry.country}.
      </p>
      <SalaryCalculator client:idle />
    </div>

    <!-- FAQ Section -->
    <div class="prose prose-slate max-w-none">
      <h2>Questions fréquentes - Frontalier {entry.country}-Luxembourg</h2>
      {entry.faqs.map((faq) => (
        <details class="border border-border rounded-lg mb-3 p-0 overflow-hidden [&[open]>summary]:border-b [&[open]>summary]:border-border">
          <summary class="cursor-pointer font-semibold py-4 px-5 bg-gray-50 hover:bg-gray-100 transition-colors list-none flex items-center justify-between">
            <span>{faq.question}</span>
            <svg class="w-5 h-5 text-gray-400 shrink-0 ml-2 transition-transform [details[open]>&]:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-5 py-4">
            <p class="text-gray-600 leading-relaxed m-0">{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>

    <!-- Cross-links to other frontalier pages -->
    <div class="bg-white rounded-xl shadow-sm border border-border p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Autres pays frontaliers</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
        {otherFrontaliers.map((f) => (
          <a
            href={`/frontalier-${f.slug}/`}
            class="block bg-gray-50 hover:bg-primary/5 border border-border hover:border-primary/30 rounded-lg p-4 text-center transition-colors"
          >
            <span class="block text-lg font-bold text-primary">Frontalier {f.country}</span>
            <span class="block text-sm text-gray-500 mt-1">Seuil télétravail : {f.teleworkThreshold} jours/an</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Cross-links to salary pages -->
    <div class="bg-white rounded-xl shadow-sm border border-border p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Exemples de salaires brut → net</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {salairesData.map((s) => (
          <a
            href={`/salaire-${s.slug}-net-luxembourg/`}
            class="block bg-gray-50 hover:bg-primary/5 border border-border hover:border-primary/30 rounded-lg p-3 text-center transition-colors"
          >
            <span class="block text-lg font-bold text-primary">{s.brutFormatted}</span>
            <span class="block text-xs text-gray-500 mt-1">brut → {s.classe1.netFormatted} net</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Cross-links to guide pages -->
    <div class="bg-white rounded-xl shadow-sm border border-border p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Guides et ressources</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <a href="/" class="block bg-gray-50 hover:bg-primary/5 border border-border hover:border-primary/30 rounded-lg p-4 transition-colors">
          <span class="block font-semibold text-gray-900">Calculateur brut → net</span>
          <span class="block text-sm text-gray-500 mt-1">Simulateur complet avec tous les paramètres</span>
        </a>
        <a href="/faq/" class="block bg-gray-50 hover:bg-primary/5 border border-border hover:border-primary/30 rounded-lg p-4 transition-colors">
          <span class="block font-semibold text-gray-900">FAQ</span>
          <span class="block text-sm text-gray-500 mt-1">Questions fréquentes sur le salaire au Luxembourg</span>
        </a>
      </div>
    </div>

    <!-- Sources -->
    <section class="mt-12 pt-8 border-t border-gray-200">
      <h3 class="text-sm font-semibold text-gray-700 mb-2">Sources</h3>
      <ul class="text-xs text-gray-500 space-y-1">
        <li><a href="https://impotsdirects.public.lu" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">Administration des contributions directes</a> — Barème et taux d'imposition</li>
        <li><a href="https://ccss.lu" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">CCSS</a> — Centre commun de la sécurité sociale</li>
      </ul>
    </section>

    <!-- Disclaimer -->
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-5">
      <p class="text-sm text-amber-800 leading-relaxed">
        <strong>Avertissement :</strong> Les informations présentées sur cette page sont fournies à titre indicatif
        et ne constituent pas un conseil fiscal ou juridique. La fiscalité transfrontalière est un domaine complexe
        soumis à des conventions bilatérales, des accords-cadres européens et des législations nationales en
        constante évolution. Les seuils de télétravail et les règles de sécurité sociale peuvent être modifiés
        par les gouvernements. Consultez un conseiller fiscal spécialisé dans la fiscalité transfrontalière
        ou l'Administration des Contributions Directes (ACD) pour une analyse personnalisée de votre situation.
      </p>
    </div>
  </div>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import SalaryCalculator from '../components/SalaryCalculator';
import { salairesData, type SalaireEntry } from '../lib/salaires-data';

export function getStaticPaths() {
  return salairesData.map((entry) => ({
    params: { brut: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: SalaireEntry;
}

const { entry } = Astro.props;

const title = `Salaire ${entry.brutFormatted} brut en net au Luxembourg - Simulateur 2026`;
const description = `Calculez le salaire net pour ${entry.brutFormatted} brut au Luxembourg en 2026. Classe 1 : ${entry.classe1.netFormatted} net. Classe 2 : ${entry.classe2.netFormatted} net. Cotisations, impôt, barèmes officiels.`;

const fmt = new Intl.NumberFormat('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const pct = (n: number) => (n * 100).toFixed(1) + ' %';

// Other salary pages for cross-links
const otherSalaires = salairesData.filter((s) => s.slug !== entry.slug);

// Breadcrumb JSON-LD
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Accueil",
      "item": "https://salairenet.lu/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": `Salaire ${entry.brutFormatted} brut en net`,
      "item": `https://salairenet.lu/salaire-${entry.slug}-net-luxembourg/`
    }
  ]
};

// FAQPage JSON-LD
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": entry.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout title={title} description={description} canonical={`https://salairenet.lu/salaire-${entry.slug}-net-luxembourg/`}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div class="space-y-10">
    <!-- Breadcrumb -->
    <nav aria-label="Fil d'Ariane" class="text-sm text-gray-500">
      <ol class="flex items-center gap-2">
        <li>
          <a href="/" class="hover:text-primary transition-colors">Accueil</a>
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <span class="text-gray-900 font-medium">Salaire {entry.brutFormatted} brut en net</span>
        </li>
      </ol>
    </nav>

    <!-- Trust badge -->
    <div class="flex flex-wrap items-center gap-3 mb-6 text-xs text-gray-500">
      <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 px-2.5 py-1 font-medium text-gray-900">
        <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
        </svg>
        Mis à jour pour 2026
      </span>
      <span>
        Par <a href="/a-propos/" class="font-medium text-gray-700 hover:text-primary">Mottalib Radif, MBA INSEAD</a>
      </span>
    </div>

    <!-- Title -->
    <div class="text-center max-w-3xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Salaire {entry.brutFormatted} brut en net au Luxembourg
      </h1>
      <p class="text-lg text-gray-600 leading-relaxed">
        Simulateur 2026 : découvrez combien vous gagnez réellement avec un salaire brut mensuel de {entry.brutFormatted} au Luxembourg, selon votre classe d'impôt.
      </p>
    </div>

    <!-- 3 Stat Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="bg-blue-50 rounded-xl border border-blue-100 p-6 text-center">
        <p class="text-sm text-gray-500 mb-2">Salaire brut mensuel</p>
        <p class="text-3xl font-bold text-primary">{fmt.format(entry.brut)} €</p>
        <p class="text-xs text-gray-400 mt-1">{fmt.format(entry.brut * 12)} € / an</p>
      </div>
      <div class="bg-orange-50 rounded-xl border border-orange-100 p-6 text-center">
        <p class="text-sm text-gray-500 mb-2">Cotisations sociales</p>
        <p class="text-3xl font-bold text-orange-600">{entry.classe1.cotisationsFormatted}</p>
        <p class="text-xs text-gray-400 mt-1">CNS + pension + dépendance</p>
      </div>
      <div class="bg-green-50 rounded-xl border border-green-100 p-6 text-center">
        <p class="text-sm text-gray-500 mb-2">Salaire net (classe 1)</p>
        <p class="text-3xl font-bold text-green-600">{entry.classe1.netFormatted}</p>
        <p class="text-xs text-gray-400 mt-1">Taux de charges : {pct(entry.classe1.tauxChargesTotal)}</p>
      </div>
    </div>

    <!-- Comparison Table by Class -->
    <div class="bg-white rounded-xl shadow-sm border border-border p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Comparaison par classe d'impôt - {entry.brutFormatted} brut</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b-2 border-gray-200">
              <th class="py-3 text-left font-semibold text-gray-700"></th>
              <th class="py-3 text-right font-semibold text-gray-700">Classe 1</th>
              <th class="py-3 text-right font-semibold text-gray-700">Classe 1a</th>
              <th class="py-3 text-right font-semibold text-gray-700">Classe 2</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="py-3 text-gray-600">Salaire brut</td>
              <td class="py-3 text-right font-medium">{fmt.format(entry.brut)} €</td>
              <td class="py-3 text-right font-medium">{fmt.format(entry.brut)} €</td>
              <td class="py-3 text-right font-medium">{fmt.format(entry.brut)} €</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-3 text-gray-600">Cotisations sociales</td>
              <td class="py-3 text-right font-medium text-orange-600">− {entry.classe1.cotisationsFormatted}</td>
              <td class="py-3 text-right font-medium text-orange-600">− {entry.classe1a.cotisationsFormatted}</td>
              <td class="py-3 text-right font-medium text-orange-600">− {entry.classe2.cotisationsFormatted}</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="py-3 text-gray-600">Impôt sur le revenu</td>
              <td class="py-3 text-right font-medium text-red-600">− {entry.classe1.impotFormatted}</td>
              <td class="py-3 text-right font-medium text-red-600">− {entry.classe1a.impotFormatted}</td>
              <td class="py-3 text-right font-medium text-red-600">− {entry.classe2.impotFormatted}</td>
            </tr>
            <tr class="border-t-2 border-gray-300 bg-gray-50">
              <td class="py-3 font-bold text-gray-900">Salaire net</td>
              <td class="py-3 text-right font-bold text-green-600">{entry.classe1.netFormatted}</td>
              <td class="py-3 text-right font-bold text-green-600">{entry.classe1a.netFormatted}</td>
              <td class="py-3 text-right font-bold text-green-600">{entry.classe2.netFormatted}</td>
            </tr>
            <tr>
              <td class="py-3 text-gray-500 text-xs">Taux de charges</td>
              <td class="py-3 text-right text-xs text-gray-500">{pct(entry.classe1.tauxChargesTotal)}</td>
              <td class="py-3 text-right text-xs text-gray-500">{pct(entry.classe1a.tauxChargesTotal)}</td>
              <td class="py-3 text-right text-xs text-gray-500">{pct(entry.classe2.tauxChargesTotal)}</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-400 mt-4">Calcul pour 0 enfant à charge, 12 mois de salaire. Barèmes 2026.</p>
    </div>

    <!-- Embedded Calculator -->
    <div>
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Simulateur personnalisé</h2>
      <p class="text-gray-600 mb-4">
        Ajustez les paramètres ci-dessous pour calculer votre salaire net avec votre situation personnelle (classe d'impôt, enfants, 13e mois, frontalier).
      </p>
      <SalaryCalculator client:idle />
    </div>

    <!-- Description / SEO content -->
    <div class="prose prose-slate max-w-none">
      <h2>Comprendre un salaire de {entry.brutFormatted} brut au Luxembourg</h2>
      <p>{entry.description}</p>

      <h2>Détail du calcul pour {entry.brutFormatted} brut</h2>
      <p>
        Le passage de {entry.brutFormatted} brut à net au Luxembourg suit un processus en deux étapes.
        Premièrement, les cotisations sociales sont prélevées : l'assurance maladie (CNS) à 2,8 %,
        l'assurance pension à 8 % et l'assurance dépendance à 1,4 %, soit un total de 12,2 % du salaire
        brut (plafonné à 13 311,69 €/mois pour la CNS et la pension). Deuxièmement, l'impôt sur le revenu
        est calculé sur le revenu imposable (brut moins cotisations, moins le forfait de frais d'obtention
        de 540 € et les dépenses spéciales forfaitaires de 480 € par an), selon le barème progressif
        à 23 tranches.
      </p>
      <p>
        Pour un salaire brut de {entry.brutFormatted} en classe 1, les cotisations mensuelles s'élèvent
        à {entry.classe1.cotisationsFormatted} et l'impôt mensuel à {entry.classe1.impotFormatted},
        laissant un salaire net de {entry.classe1.netFormatted}. En classe 2, grâce au splitting fiscal,
        l'impôt est réduit à {entry.classe2.impotFormatted} par mois, portant le net
        à {entry.classe2.netFormatted}.
      </p>
    </div>

    <!-- FAQ Section -->
    <div class="prose prose-slate max-w-none">
      <h2>Questions fréquentes - Salaire {entry.brutFormatted} brut au Luxembourg</h2>
      {entry.faqs.map((faq) => (
        <details class="border border-border rounded-lg mb-3 p-0 overflow-hidden [&[open]>summary]:border-b [&[open]>summary]:border-border">
          <summary class="cursor-pointer font-semibold py-4 px-5 bg-gray-50 hover:bg-gray-100 transition-colors list-none flex items-center justify-between">
            <span>{faq.question}</span>
            <svg class="w-5 h-5 text-gray-400 shrink-0 ml-2 transition-transform [details[open]>&]:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-5 py-4">
            <p class="text-gray-600 leading-relaxed m-0">{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>

    <!-- Cross-links to other salary pages -->
    <div class="bg-white rounded-xl shadow-sm border border-border p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Autres niveaux de salaire</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {otherSalaires.map((s) => (
          <a
            href={`/salaire-${s.slug}-net-luxembourg/`}
            class="block bg-gray-50 hover:bg-primary/5 border border-border hover:border-primary/30 rounded-lg p-3 text-center transition-colors"
          >
            <span class="block text-lg font-bold text-primary">{s.brutFormatted}</span>
            <span class="block text-xs text-gray-500 mt-1">brut → {s.classe1.netFormatted} net</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Cross-links to guide pages -->
    <div class="bg-white rounded-xl shadow-sm border border-border p-6">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">Guides et ressources</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
        <a href="/" class="block bg-gray-50 hover:bg-primary/5 border border-border hover:border-primary/30 rounded-lg p-4 transition-colors">
          <span class="block font-semibold text-gray-900">Calculateur brut → net</span>
          <span class="block text-sm text-gray-500 mt-1">Simulateur complet avec tous les paramètres</span>
        </a>
        <a href="/faq/" class="block bg-gray-50 hover:bg-primary/5 border border-border hover:border-primary/30 rounded-lg p-4 transition-colors">
          <span class="block font-semibold text-gray-900">FAQ</span>
          <span class="block text-sm text-gray-500 mt-1">Questions fréquentes sur le salaire au Luxembourg</span>
        </a>
        <a href="/frontalier-france/" class="block bg-gray-50 hover:bg-primary/5 border border-border hover:border-primary/30 rounded-lg p-4 transition-colors">
          <span class="block font-semibold text-gray-900">Frontalier France</span>
          <span class="block text-sm text-gray-500 mt-1">Fiscalité des frontaliers français</span>
        </a>
        <a href="/frontalier-belgique/" class="block bg-gray-50 hover:bg-primary/5 border border-border hover:border-primary/30 rounded-lg p-4 transition-colors">
          <span class="block font-semibold text-gray-900">Frontalier Belgique</span>
          <span class="block text-sm text-gray-500 mt-1">Fiscalité des frontaliers belges</span>
        </a>
        <a href="/frontalier-allemagne/" class="block bg-gray-50 hover:bg-primary/5 border border-border hover:border-primary/30 rounded-lg p-4 transition-colors">
          <span class="block font-semibold text-gray-900">Frontalier Allemagne</span>
          <span class="block text-sm text-gray-500 mt-1">Fiscalité des frontaliers allemands</span>
        </a>
      </div>
    </div>

    <!-- Sources -->
    <section class="mt-12 pt-8 border-t border-gray-200">
      <h3 class="text-sm font-semibold text-gray-700 mb-2">Sources</h3>
      <ul class="text-xs text-gray-500 space-y-1">
        <li><a href="https://impotsdirects.public.lu" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">Administration des contributions directes</a> — Barème et taux d'imposition</li>
        <li><a href="https://ccss.lu" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">CCSS</a> — Centre commun de la sécurité sociale</li>
      </ul>
    </section>

    <!-- Disclaimer -->
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-5">
      <p class="text-sm text-amber-800 leading-relaxed">
        <strong>Avertissement :</strong> Les montants affichés sont des estimations basées sur les barèmes fiscaux
        et sociaux luxembourgeois en vigueur au 1<sup>er</sup> janvier 2026. Les résultats réels peuvent varier
        en fonction de déductions spécifiques (frais réels, assurance complémentaire, intérêts d'emprunt),
        des revenus du conjoint en classe 2, et de dispositions individuelles. Ce simulateur ne constitue pas
        un conseil fiscal. Consultez l'Administration des Contributions Directes (ACD) ou un conseiller fiscal
        agréé pour une analyse personnalisée de votre situation.
      </p>
    </div>
  </div>
</Layout>
